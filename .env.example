# OpenMetadata
OPENMETADATA_HOST=http://openmetadata-server:8585
OPENMETADATA_JWT_TOKEN=your-jwt-token-here

# Graphiti/FalkorDB
FALKORDB_HOST=falkordb
FALKORDB_PORT=6379
GRAPHITI_MCP_URL=http://graphiti-mcp:8200/mcp/

# LLM Providers
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
GROQ_API_KEY=your-groq-key
LITELLM_MASTER_KEY=sk-chronos-local
LITELLM_PROXY_URL=http://litellm-proxy:4000

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_CHANNEL=#data-incidents

# Langfuse (Agentic Observability)
LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-chronos-demo
LANGFUSE_SECRET_KEY=sk-lf-chronos-demo

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=chronos

# Application
VERSION=2.0.0
ENVIRONMENT=development
DEBUG=false
INVESTIGATION_WINDOW_HOURS=72
INVESTIGATION_DEDUP_WINDOW_SECONDS=300
LINEAGE_UPSTREAM_DEPTH=5
LINEAGE_DOWNSTREAM_DEPTH=3
LOG_LEVEL=INFO
