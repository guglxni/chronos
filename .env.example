# ─── OpenMetadata ──────────────────────────────────────────────────────────────
OPENMETADATA_HOST=http://openmetadata-server:8585
# Required secret — obtain from OpenMetadata Settings > Bots
OPENMETADATA_JWT_TOKEN=

# ─── Graphiti / FalkorDB ───────────────────────────────────────────────────────
FALKORDB_HOST=falkordb
FALKORDB_PORT=6379
GRAPHITI_MCP_URL=http://graphiti-mcp:8200/sse

# ─── LLM Providers ────────────────────────────────────────────────────────────
# Supply at least one of the provider keys below; LiteLLM will route accordingly.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
# Used to authenticate the LiteLLM proxy.  Generate a strong random value:
#   python -c "import secrets; print('sk-' + secrets.token_hex(24))"
LITELLM_MASTER_KEY=
LITELLM_PROXY_URL=http://litellm-proxy:4000

# ─── Slack ─────────────────────────────────────────────────────────────────────
# Optional.  Leave empty to disable Slack notifications.
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#data-incidents

# ─── Langfuse (Agentic Observability) ─────────────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://langfuse:3000
# Required when LANGFUSE_ENABLED=true.  Obtain from your Langfuse project settings.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ─── Webhook Signature Verification ───────────────────────────────────────────
# Set to true in production to enforce HMAC-SHA256 payload signing.
# Must also set WEBHOOK_HMAC_SECRET to a strong random value when enabled.
WEBHOOK_SIGNATURE_REQUIRED=false
# Generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_HMAC_SECRET=

# ─── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=chronos

# ─── Service URLs ──────────────────────────────────────────────────────────────
# Used in outbound Slack notification links.  In production set to your public URLs.
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8100

# ─── Docker Compose secrets (required to start the compose stack) ──────────────
# These are consumed by docker-compose.yml via ${VAR:?} substitution.
# Generate strong values:  python -c "import secrets; print(secrets.token_hex(24))"
MYSQL_ROOT_PASSWORD=
LANGFUSE_DB_PASSWORD=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=

# ─── Application ───────────────────────────────────────────────────────────────
VERSION=2.0.0
# Set to "production" to enforce additional secret validation at startup
ENVIRONMENT=development
DEBUG=false
# Comma-separated list of trusted frontend origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
INVESTIGATION_WINDOW_HOURS=72
INVESTIGATION_DEDUP_WINDOW_SECONDS=300
# Wall-clock timeout (seconds) for a single graph.ainvoke call.  Hung MCP calls
# will be cancelled after this interval and the investigation set to error state.
INVESTIGATION_TIMEOUT_SECONDS=300
LINEAGE_UPSTREAM_DEPTH=5
LINEAGE_DOWNSTREAM_DEPTH=3
LOG_LEVEL=INFO
