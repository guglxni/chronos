# Frontend environment variables (build-time, baked into the Vite bundle).
#
# On Vercel: set VITE_API_URL in Project Settings → Environment Variables
# for each target scope (Development / Preview / Production).
#
# For local dev with docker compose, the root .env provides VITE_API_URL
# via the compose build-arg passthrough. No action needed for local.

# Absolute URL of the CHRONOS FastAPI backend — where the SPA makes API + SSE calls.
# Production example: https://chronos-api.example.com
# Preview example:    https://chronos-api-staging.example.com
# Local example:      http://localhost:8100
VITE_API_URL=http://localhost:8100

# When "true", the frontend uses fixture data instead of the live backend.
# Useful for shareable preview deploys before the backend is hosted publicly.
# Leave unset (or "false") for local dev against a running docker-compose stack.
VITE_DEMO_MODE=false
